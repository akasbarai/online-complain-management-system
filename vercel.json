{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/officer/:path*",
      "destination": "/officer/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
