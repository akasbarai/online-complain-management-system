DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=ocms
DB_PORT=3306
DB_CONNECT_TIMEOUT=30000
JWT_SECRET=replace_with_a_long_random_string
ADMIN_PASSWORD=change_this_before_seeding
PORT=4000
CORS_ORIGINS=https://ocms.akashbarai.com.np
SLA_SIMULATION_DAYS=0
USER_PORTAL_URL=https://ocms.akashbarai.com.np

# Gmail SMTP for automatic account verification acknowledgement emails.
# Use a Google App Password, not your normal Gmail password.
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MAIL_FROM="OCMS Admin <your_gmail_address@gmail.com>"

# Optional generic SMTP alternative. Leave these blank when using Gmail above.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# MAIL_FROM="OCMS Admin <no-reply@example.com>"
